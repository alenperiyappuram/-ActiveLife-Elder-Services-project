@model ActiveLifeElderServices.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-container">
    <h2>Login to ActiveLife</h2>
    <form asp-action="Login" asp-controller="Account" method="post">
        @Html.AntiForgeryToken() @* This generates the anti-forgery token *@
        <div class="mb-3 text-start">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control rounded-pill px-3 py-2" placeholder="Enter your username">
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>
        <div class="mb-3 text-start">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control rounded-pill px-3 py-2" placeholder="Enter your password">
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="d-grid gap-2 mb-3">
            <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">Login</button>
        </div>
        <p class="text-muted">Don't have an account? <a asp-action="Register" asp-controller="Account" class="text-decoration-none text-primary">Sign Up</a></p>

        <!-- Display server-side validation summary -->
        <div asp-validation-summary="ModelOnly" class="text-danger alert-message alert-danger" style="display: block;"></div>
        @* The client-side message box can still be used for immediate feedback *@
        <div id="messageBox" class="alert-message"></div>
    </form>
</div>


  