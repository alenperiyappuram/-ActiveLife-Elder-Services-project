@model ActiveLifeElderServices.Models.BookAppointmentViewModel
@using ActiveLifeElderServices.Models

@{
    ViewData["Title"] = "Book an Appointment";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg p-4">
                <h2 class="text-center text-primary mb-4">Book Your Service Appointment</h2>
                <p class="text-center text-muted mb-4">
                    Fill out the form below to request an appointment. Our team will contact you shortly to confirm the details.
                </p>

                <form asp-action="Book" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="ClientName" class="form-label"></label>
                        <input asp-for="ClientName" class="form-control rounded-pill px-3 py-2" placeholder="Enter your full name or client's name" />
                        <span asp-validation-for="ClientName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control rounded-pill px-3 py-2" placeholder="Enter your email address" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactPhoneNumber" class="form-label"></label>
                        <input asp-for="ContactPhoneNumber" class="form-control rounded-pill px-3 py-2" type="tel" placeholder="e.g., +91 98765 43210" />
                        <span asp-validation-for="ContactPhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AlternatePhoneNumber" class="form-label"></label>
                        <input asp-for="AlternatePhoneNumber" class="form-control rounded-pill px-3 py-2" type="tel" placeholder="Optional alternate number" />
                        <span asp-validation-for="AlternatePhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SelectedServiceType" class="form-label"></label>
                        <select asp-for="SelectedServiceType" asp-items="ViewBag.ServiceTypes" class="form-select rounded-pill px-3 py-2">
                            <option value="">-- Select a Service --</option>
                        </select>
                        <span asp-validation-for="SelectedServiceType" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AppointmentDate" class="form-label"></label>
                        <input asp-for="AppointmentDate" class="form-control rounded-pill px-3 py-2" type="date" />
                        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AppointmentTime" class="form-label"></label>
                        <input asp-for="AppointmentTime" class="form-control rounded-pill px-3 py-2" type="time" />
                        <span asp-validation-for="AppointmentTime" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control rounded-pill px-3 py-2" placeholder="e.g., House No, Street, Area, City" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NearestLandmark" class="form-label"></label>
                        <input asp-for="NearestLandmark" class="form-control rounded-pill px-3 py-2" placeholder="e.g., Near Apollo Hospital" />
                        <span asp-validation-for="NearestLandmark" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactAddress" class="form-label"></label>
                        <input asp-for="ContactAddress" class="form-control rounded-pill px-3 py-2" placeholder="Used for correspondence, if different from service address" />
                        <span asp-validation-for="ContactAddress" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AdditionalRequirements" class="form-label"></label>
                        <textarea asp-for="AdditionalRequirements" class="form-control rounded-pill px-3 py-2" rows="4" placeholder="Any specific needs or requests for the service (e.g., 'Requires wheelchair access', 'Prefers morning visits')"></textarea>
                        <span asp-validation-for="AdditionalRequirements" class="text-danger"></span>
                    </div>

                    <div class="mb-3" id="caregiverGenderPreferenceGroup">
                        <label asp-for="CaregiverGenderPreference" class="form-label"></label>
                        <select asp-for="CaregiverGenderPreference" asp-items="ViewBag.CaregiverGenderOptions" class="form-select rounded-pill px-3 py-2"></select>
                        <span asp-validation-for="CaregiverGenderPreference" class="text-danger"></span>
                    </div>
                    <p class="text-muted small mt-2">
                        <em>Gender preference is applicable for services like "Medical Escort & Support", "In-Home Care & Assistance", and "Gardening & Outdoor Support".</em>
                    </p>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">Submit Appointment Request</button>
                        <a asp-action="Index" asp-controller="Dashboard" class="btn btn-outline-secondary rounded-pill px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Get references to elements
            var serviceTypeSelect = document.getElementById('SelectedServiceType');
            var caregiverGenderGroup = document.getElementById('caregiverGenderPreferenceGroup'); // Targeted by ID now

            // Define services where gender preference is applicable
            var genderApplicableServices = [
                "Medical Escort & Support",
                "In-Home Care & Assistance",
                "Gardening & Outdoor Support"
            ];

            // Function to toggle gender preference field visibility
            function toggleGenderPreference() {
                var selectedService = serviceTypeSelect.value;
                if (genderApplicableServices.includes(selectedService)) {
                    caregiverGenderGroup.style.display = 'block';
                } else {
                    caregiverGenderGroup.style.display = 'none';
                    // Clear value when hidden to prevent unwanted data submission
                    document.getElementById('CaregiverGenderPreference').value = '';
                }
            }

            // Initial call to set correct visibility on page load
            toggleGenderPreference();

            // Add event listener for when the service type changes
            serviceTypeSelect.addEventListener('change', toggleGenderPreference);

            // Client-side date and time validation/initialization
            var appointmentDateInput = document.getElementById('AppointmentDate');
            var appointmentTimeInput = document.getElementById('AppointmentTime');

            if (appointmentDateInput && appointmentTimeInput) {
                var now = new Date(); // Current client-side time (Local Time)

                // Set min attribute for AppointmentDate to prevent past dates
                var year = now.getFullYear();
                var month = (now.getMonth() + 1).toString().padStart(2, '0');
                var day = now.getDate().toString().padStart(2, '0');
                var minDate = `${year}-${month}-${day}`;
                appointmentDateInput.setAttribute('min', minDate);

                // Initialize date input if empty or invalid default from server
                if (!appointmentDateInput.value || new Date(appointmentDateInput.value) < new Date(minDate)) {
                    appointmentDateInput.value = minDate;
                }

                // Function to set the minimum time based on the selected date
                function setMinTime() {
                    var selectedDate = new Date(appointmentDateInput.value);
                    var today = new Date();
                    today.setHours(0, 0, 0, 0); // Normalize today to start of day

                    // If selected date is today
                    if (selectedDate.getTime() === today.getTime()) {
                        var currentHour = now.getHours();
                        var currentMinute = now.getMinutes() + 5; // Add a 5-minute buffer

                        // Handle minute overflow (e.g., 55 + 5 = 60 minutes -> next hour)
                        if (currentMinute >= 60) {
                            currentHour++;
                            currentMinute = currentMinute % 60;
                        }

                        // Cap at 23:59 if buffer pushes to next day (prevents invalid time in picker)
                        if (currentHour > 23) {
                            currentHour = 23;
                            currentMinute = 59;
                        }

                        var minTime = `${currentHour.toString().padStart(2, '0')}:${currentMinute.toString().padStart(2, '0')}`;
                        appointmentTimeInput.setAttribute('min', minTime);

                        // If the currently selected time is in the past for today, update it
                        if (appointmentTimeInput.value && appointmentTimeInput.value < minTime) {
                            appointmentTimeInput.value = minTime;
                        } else if (!appointmentTimeInput.value) {
                            // If time input is empty and date is today, set a default from now
                             appointmentTimeInput.value = minTime;
                        }
                    } else {
                        // If selected date is a future date, remove min time restriction
                        appointmentTimeInput.removeAttribute('min');
                        // Optionally set a sensible default for future dates if empty
                        if (!appointmentTimeInput.value) {
                            appointmentTimeInput.value = "09:00"; // Default to 9 AM for future dates
                        }
                    }
                }

                // Initial setting of minimum time and default value on page load
                // This is important for when the page first loads with today's date selected.
                setMinTime();

                // Add event listener for date change to adjust time min/value
                appointmentDateInput.addEventListener('change', setMinTime);
            }
        });
    </script>
}