@model List<ActiveLifeElderServices.Models.Appointment>

@{
    ViewData["Title"] = "My Upcoming Appointments"; @* Changed Title *@
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="card p-4 shadow-sm">
        <h2 class="text-primary mb-4 text-center">My Upcoming Appointments</h2> @* Changed Heading *@

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info" role="alert">
                You currently have no upcoming appointments scheduled. <a asp-action="Book" class="alert-link">Book one now!</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                           
                            <th>Service Type</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Client Name</th>
                            <th>Email</th>
                            <th>Contact No.</th>
                            <th>Address</th>
                            <th>Landmark</th>
                            <th>Gender Pref.</th>
                            <th>Booked On</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model)
                        {
                            <tr>
                             
                                <td>@appointment.ServiceType</td>
                                <td>@appointment.AppointmentDate.ToString("yyyy-MM-dd")</td>
                                <td>@appointment.AppointmentTime.ToString(@"hh\:mm")</td>
                                <td><span class="badge @(appointment.Status == "Pending" ? "bg-warning" : appointment.Status == "Confirmed" ? "bg-success" : "bg-secondary")">@appointment.Status</span></td>
                                <td>@appointment.ClientName</td>
                                <td>@appointment.Email</td>
                                <td>@appointment.ContactPhoneNumber</td>
                                <td>@appointment.Address</td>
                                <td>@(string.IsNullOrEmpty(appointment.NearestLandmark) ? "N/A" : appointment.NearestLandmark)</td>
                                <td>@(string.IsNullOrEmpty(appointment.CaregiverGenderPreference) ? "N/A" : appointment.CaregiverGenderPreference)</td>
                                <td>@appointment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        <div class="mt-3 text-center">
            <a asp-action="Book" class="btn btn-primary rounded-pill px-4">Book Another Appointment</a>
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Back to Dashboard</a>
        </div>
    </div>
</div>