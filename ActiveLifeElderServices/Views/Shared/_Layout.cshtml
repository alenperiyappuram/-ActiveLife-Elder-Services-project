<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ActiveLifeElderServices</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Your custom CSS can go here or in a separate file -->
    <style>
        
        /* Base body styles for the entire application */
        html, body {
            height: 100%; /* Ensure html and body take full height */
            margin: 0;
        }

        body {
            display: flex; /* Use flexbox for overall layout */
            flex-direction: column; /* Arrange children vertically */
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa; /* Light grey background */
        }

        .navbar {
            background-color: #007bff; /* Primary blue for navbar */
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }

        .navbar-brand {
            font-weight: 700;
            color: #fff !important;
            font-size: 1.8rem;
        }

        .nav-link {
            color: #fff !important;
            font-weight: 500;
            margin-right: 15px;
            transition: color 0.3s ease;
        }

            .nav-link:hover {
                color: #e2e6ea !important; /* Lighter white on hover */
            }

        .btn-outline-light {
            border-color: #fff;
            color: #fff;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

            .btn-outline-light:hover {
                background-color: #fff;
                color: #007bff;
            }

        .hero-section {
            background: linear-gradient(to right, #007bff, #0056b3); /* Blue gradient */
            color: #fff;
            padding: 100px 0;
            text-align: center;
            border-radius: 0 0 15px 15px; /* Rounded bottom corners */
            box-shadow: 0 4px 8px rgba(0,0,0,.2);
        }

            .hero-section h1 {
                font-size: 3.5rem;
                font-weight: 700;
                margin-bottom: 20px;
            }

            .hero-section p {
                font-size: 1.5rem;
                margin-bottom: 40px;
            }

        /* Main content area styling */
        .main-content-wrapper {
            flex-grow: 1; /* Allows this div to take up remaining vertical space */
            display: flex; /* Make it a flex container */
            flex-direction: column; /* Arrange children vertically */
            justify-content: flex-start; /* Default alignment for main content */
            padding-top: 20px; /* Add some padding from navbar */
            padding-bottom: 20px; /* Add some padding before footer */
            width: 100%; /* Ensure it takes full width */
        }

            /* Specific styling for centered pages (like Login/Register) */
            .main-content-wrapper.centered-page-layout {
                background-color: #e9ecef; /* Lighter grey background for centered pages */
                justify-content: center; /* Center content vertically */
                align-items: center; /* Center content horizontally */
                padding: 0; /* Remove padding if you want the form container to define its own */
            }

        /* Styles for login/register containers */
        .login-container, .register-container {
            background-color: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,.15);
            width: 100%;
            max-width: 450px; /* Max width for the form */
            text-align: center;
            margin: auto; /* Center the container within its flex parent */
        }

            .login-container h2, .register-container h2 {
                color: #007bff;
                margin-bottom: 30px;
                font-weight: 700;
            }

        .form-control {
            border-radius: 8px;
            padding: 12px 15px;
            border: 1px solid #ced4da;
        }

            .form-control:focus {
                border-color: #007bff;
                box-shadow: 0 0 0 0.25rem rgba(0, 123, 255, 0.25);
            }

        .btn-primary {
            background-color: #007bff;
            border-color: #007bff;
            border-radius: 8px;
            padding: 12px 25px;
            font-weight: 600;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #0056b3;
                border-color: #0056b3;
            }

        .form-label {
            font-weight: 500;
            color: #495057;
            text-align: left;
            display: block;
            margin-bottom: 5px;
        }

        .alert-message {
            margin-top: 20px;
            padding: 15px;
            border-radius: 8px;
            /* display: none; */ /* Do not set display: none here, let razor control it */
            font-weight: 500;
        }

        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .alert-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        /* Footer styling */
        footer {
            background-color: #343a40; /* Dark footer */
            color: #fff;
            padding: 30px 0;
            text-align: center;
            margin-top: auto; /* Pushes footer to the bottom if parent is flex */
            border-radius: 15px 15px 0 0; /* Rounded top corners */
            width: 100%;
            flex-shrink: 0; /* Prevent footer from shrinking */
        }

        /* Activity Generator Section (from Index page) */
        .activity-generator-section {
            background-color: #e6f2ff; /* Light blue background */
            padding: 40px;
            border-radius: 10px;
            margin-top: 50px;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
        }

            .activity-generator-section h3 {
                color: #007bff;
                font-weight: 600;
                margin-bottom: 20px;
            }

        .activity-output {
            background-color: #f0f8ff;
            border: 1px solid #cce5ff;
            border-radius: 8px;
            padding: 20px;
            min-height: 100px;
            margin-top: 20px;
            text-align: left;
            white-space: pre-wrap;
            word-wrap: break-word;
        }

        .loading-spinner {
            display: none;
            margin-top: 20px;
        }

        /* Sidebar specific styles */
        .sidebar-card {
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
            margin-bottom: 20px;
            background-color: #fff; /* White background for sidebar card */
        }

        .sidebar-header {
            background-color: #007bff;
            color: #fff;
            font-weight: 600;
            padding: 15px;
            border-radius: 15px 15px 0 0;
        }

        .sidebar-item {
            padding: 12px 15px;
            color: #343a40;
            border-left: 5px solid transparent;
            transition: background-color 0.2s ease, border-left-color 0.2s ease;
        }

            .sidebar-item:hover {
                background-color: #e9ecef;
                border-left-color: #007bff;
                color: #007bff;
            }

            .sidebar-item i {
                width: 20px; /* Ensure consistent icon spacing */
                text-align: center;
            }
            .logout_style{
                padding-bottom:10px;
            }
        /* Dashboard content card */
        .dashboard-content-card {
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
            background-color: #fff;
        }

        .action-card {
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
            transition: transform 0.2s ease;
        }

            .action-card:hover {
                transform: translateY(-3px);
            }
    </style>
  


</head>
<body>
    <header>
        <!-- Navigation Bar -->
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">ActiveLife Elder Services</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @* Authenticated User Navbar Items *@
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Appointment/Book">Schedule an Appointment</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Help</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Services/Index">Services</a>
                            </li>
                            <li class="nav-item ">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link btn btn-outline-light rounded-pill px-3 ">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            @* Public User Navbar Items *@
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Home" && ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index" aria-current="page">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-light rounded-pill px-3" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Appointments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Career</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Services</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Contact Us</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Help</a>
                            </li>
                          
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @* Main content wrapper - adjusts layout based on controller *@
    @{
        string controllerName = ViewContext.RouteData.Values["Controller"].ToString();
        string mainContentClass = "container main-content-wrapper"; // Default for Home, etc.
        if (controllerName == "Account")
        {
            mainContentClass = "main-content-wrapper centered-page-layout"; // For Login/Register
        }
        else if (controllerName == "Dashboard")
        {
            mainContentClass = "container-fluid main-content-wrapper"; // For Dashboard with sidebar
        }
    }

    <div class="@mainContentClass">
        @RenderBody()
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <p>&copy; 2025 ActiveLife Elder Services. All rights reserved.</p>
            <p>123 AGP Arcade, Piravom, Kerala,686664</p>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
